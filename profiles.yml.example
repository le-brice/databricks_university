# Copy this file to ~/.dbt/profiles.yml and fill in your values.
# Not needed when using the dbt Cloud CLI (connection is managed in dbt Cloud UI).

tue_databricks:
  target: dev
  outputs:
    dev:
      type: databricks
      host: "{{ env_var('DATABRICKS_HOST') }}"           # e.g. adb-xxxx.azuredatabricks.net
      http_path: "{{ env_var('DATABRICKS_HTTP_PATH') }}" # /sql/1.0/warehouses/xxxx
      token: "{{ env_var('DATABRICKS_TOKEN') }}"
      catalog: demo_tue   # Unity Catalog — requires dbt-databricks >= 1.6
      schema: staging     # default schema (overridden per layer via dbt_project.yml)
      threads: 8
